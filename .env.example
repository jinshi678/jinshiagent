# JinshiAgent 环境变量配置
# 复制此文件为 .env 并填写实际值

# ── LLM 配置 ──────────────────────────────────────
# OpenAI API 密钥（必填）
OPENAI_API_KEY=sk-your-api-key-here

# API 基础 URL（支持 OpenAI 兼容接口，如 DeepSeek、通义千问等）
OPENAI_API_BASE=https://api.openai.com/v1

# 模型名称
JINSHI_MODEL=gpt-4o

# ── API 服务配置 ──────────────────────────────────
# API 服务端口
JINSHI_PORT=8000

# API 认证密钥（留空则不启用认证）
# 生产环境强烈建议设置
JINSHI_API_KEY=

# ── 可选：Docker 部署时使用 ─────────────────────
# 腾讯云/阿里云等服务器部署时，使用内网地址加速
# OPENAI_API_BASE=https://your-proxy.example.com/v1
